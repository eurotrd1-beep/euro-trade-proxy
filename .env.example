# ── Set these in Render → Environment Variables (NOT committed here) ──

# Shared (TradingView + OTC):
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# OTC (Pocket Option) — DIRECT WebSocket, no browser.
# Capture PO_WS_URL + PO_AUTH once with:  node get-po-ssid.js  (run locally)
PO_WS_URL=wss://api-eu.po.market/socket.io/?EIO=4&transport=websocket
PO_AUTH=["auth",{"session":"...","isDemo":1,...}]

# Credentials — enable AUTOMATIC token re-capture (brief temporary browser) if
# the token ever dies despite the heartbeat. Optional but recommended.
PO_EMAIL=your_email@example.com
PO_PASSWORD=your_password

# ── Optional tuning (override with REAL frames from get-po-ssid.js) ──
# PO_IS_DEMO=1
# PO_LOGIN_URL=https://pocketoption.com/en/login/
# PO_HEARTBEAT=["42[\"ps\"]"]                 # extra keep-alive frames per beat
# PO_SUBSCRIBE=42["changeSymbol",{"asset":"{symbol}","period":60}]
# PO_KEEPALIVE_URL=https://pocketoption.com/en/cabinet/   # 2nd keep-alive channel
# PO_COOKIE=ci_session=...; other=...                     # cookie for the HTTP channel
# OTC_AUTOSTART=0                              # disable the OTC scraper entirely
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium  # only for auto-recapture, if needed
