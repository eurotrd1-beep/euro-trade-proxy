# ── Set these in Render → Environment Variables (NOT committed here) ──

# TradingView scraper + OTC scraper share these:
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# OTC (Pocket Option) scraper — persistent browser session:
PO_EMAIL=your_email@example.com
PO_PASSWORD=your_password
PO_CHART_URL=https://pocketoption.com/en/cabinet/demo-quick-high-low/
# Optional overrides:
# PO_LOGIN_URL=https://pocketoption.com/en/login/
# OTC_AUTOSTART=0           # set to 0 to disable the OTC scraper
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium   # if using a system Chromium
